{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"
    }
  ],
  "crons": [
    {
      "path": "/api/scan",
      "schedule": "* * * * *"
    }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 300
    }
  }
}
